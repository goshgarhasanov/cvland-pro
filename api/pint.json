{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "strict_param": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "single_quote": true,
        "concat_space": {
            "spacing": "one"
        },
        "binary_operator_spaces": {
            "default": "single_space"
        },
        "global_namespace_import": {
            "import_classes": true,
            "import_constants": false,
            "import_functions": false
        },
        "phpdoc_align": {
            "align": "left"
        },
        "phpdoc_separation": true,
        "phpdoc_order": true
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor"
    ]
}
